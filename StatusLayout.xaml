<UserControl x:Class="dot_net_fm.StatusLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource StatusBarBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- View mode buttons (bottom-left) -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
            <Button Width="20" Height="20" Background="Transparent" BorderThickness="0" Margin="2,0" Cursor="Hand">
                <Viewbox Width="12" Height="12" Stretch="Uniform">
                    <Canvas Width="12" Height="12">
                        <Path Data="M1,6 L6,1 L11,6" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.5" StrokeLineJoin="Round"/>
                        <Line X1="6" Y1="1" X2="6" Y2="10" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.5"/>
                    </Canvas>
                </Viewbox>
            </Button>
            <Button Width="20" Height="20" Background="Transparent" BorderThickness="0" Margin="2,0" Cursor="Hand">
                <Viewbox Width="12" Height="12" Stretch="Uniform">
                    <Canvas Width="12" Height="12">
                        <Rectangle Canvas.Left="0" Canvas.Top="0" Width="5" Height="2" Fill="{StaticResource TextSecondaryBrush}"/>
                        <Rectangle Canvas.Left="0" Canvas.Top="5" Width="5" Height="2" Fill="{StaticResource TextSecondaryBrush}"/>
                        <Rectangle Canvas.Left="0" Canvas.Top="10" Width="5" Height="2" Fill="{StaticResource TextSecondaryBrush}"/>
                        <Line X1="7" Y1="1" X2="11" Y2="1" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1"/>
                        <Line X1="7" Y1="6" X2="11" Y2="6" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1"/>
                        <Line X1="7" Y1="11" X2="11" Y2="11" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1"/>
                    </Canvas>
                </Viewbox>
            </Button>
            <Button Width="20" Height="20" Background="Transparent" BorderThickness="0" Margin="2,0" Cursor="Hand">
                <Viewbox Width="12" Height="12" Stretch="Uniform">
                    <Canvas Width="12" Height="12">
                        <Line X1="6" Y1="0" X2="6" Y2="12" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.5"/>
                        <Rectangle Canvas.Left="1" Canvas.Top="1" Width="4" Height="4" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1" Fill="Transparent"/>
                        <Rectangle Canvas.Left="8" Canvas.Top="1" Width="4" Height="4" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1" Fill="Transparent"/>
                    </Canvas>
                </Viewbox>
            </Button>
        </StackPanel>

        <!-- Status text -->
        <TextBlock x:Name="StatusTextBlock" Grid.Column="1" Text="" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Zoom slider (bottom-right) — steps: 24, 32, 48, 64, 128, 256 -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
            <Slider x:Name="ZoomSlider" Width="80" Height="14" Background="Transparent" BorderThickness="0"
                    ValueChanged="ZoomSlider_ValueChanged"
                    Style="{StaticResource ZoomSliderStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>
