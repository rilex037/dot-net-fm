<Application x:Class="dot_net_fm.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:dot_net_fm"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <local:StringToUriConverter x:Key="StringToUriConverter"/>
        <local:IconSizeStepConverter x:Key="IconSizeStepConverter"/>

        <!-- Global Styles -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- Zoom Thumb Style -->
        <Style x:Key="ZoomThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Width="12" Height="12"
                                 Fill="{StaticResource SliderThumbBrush}"
                                 Stroke="{StaticResource SliderThumbBrush}"
                                 StrokeThickness="0.5"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Zoom Slider Style - snaps to 6 discrete icon-size steps (0-5) -->
        <Style x:Key="ZoomSliderStyle" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="5"/>
            <Setter Property="Value" Value="2"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="IsDirectionReversed" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="14" SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Track line -->
                            <Border Grid.Row="0" Height="4"
                                    Background="{StaticResource SliderTrackBrush}"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"/>
                            <!-- Track with interactive Thumb -->
                            <Track x:Name="PART_Track" Grid.Row="0"
                                   VerticalAlignment="Center">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="12" Height="12"
                                           Style="{StaticResource ZoomThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
