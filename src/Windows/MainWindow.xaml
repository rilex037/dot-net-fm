<Window x:Class="dot_net_fm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dot_net_fm"
        mc:Ignorable="d"
        Title="Home" Height="768" Width="1024"
        WindowStyle="None"
        WindowState="Normal"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.InputBindings>
        <KeyBinding Command="{x:Static local:CommandIds.Exit}"     Key="F4"       Modifiers="Alt"/>
        <KeyBinding Command="{x:Static local:CommandIds.Rename}"   Key="F2"/>
        <KeyBinding Command="{x:Static local:CommandIds.Delete}"   Key="Delete"/>
        <KeyBinding Command="{x:Static local:CommandIds.Copy}"     Key="C"        Modifiers="Control"/>
        <KeyBinding Command="{x:Static local:CommandIds.Cut}"      Key="X"        Modifiers="Control"/>
        <KeyBinding Command="{x:Static local:CommandIds.Paste}"    Key="V"        Modifiers="Control"/>
        <KeyBinding Command="{x:Static local:CommandIds.Refresh}"  Key="F5"/>
        <KeyBinding Command="{x:Static local:CommandIds.ZoomIn}"   Key="OemPlus"  Modifiers="Control"/>
        <KeyBinding Command="{x:Static local:CommandIds.ZoomOut}"  Key="OemMinus" Modifiers="Control"/>
        <KeyBinding Command="{x:Static local:CommandIds.NewTab}"   Key="T"        Modifiers="Control"/>
        <KeyBinding Command="{x:Static local:CommandIds.CloseTab}" Key="W"        Modifiers="Control"/>
        <KeyBinding Command="{x:Static local:CommandIds.NextTab}"  Key="Tab"      Modifiers="Control"/>
        <KeyBinding Command="{x:Static local:CommandIds.PrevTab}"  Key="Tab"      Modifiers="Control+Shift"/>
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:CommandIds.Exit}"
                        Executed="Exit_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.Rename}"
                        Executed="Rename_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.Delete}"
                        Executed="Delete_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.Copy}"
                        Executed="Copy_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.Cut}"
                        Executed="Cut_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.Paste}"
                        Executed="Paste_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.Refresh}"
                        Executed="Refresh_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.ZoomIn}"
                        Executed="ZoomIn_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.ZoomOut}"
                        Executed="ZoomOut_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.NewTab}"
                        Executed="NewTab_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.CloseTab}"
                        Executed="CloseTab_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.NextTab}"
                        Executed="NextTab_Executed"/>
        <CommandBinding Command="{x:Static local:CommandIds.PrevTab}"
                        Executed="PrevTab_Executed"/>
    </Window.CommandBindings>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="{StaticResource SizeTitleBarHeight}" GlassFrameThickness="0" CornerRadius="20" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: Title Bar (Caption area) -->
        <local:TitleBar x:Name="TitleBar" Grid.Row="0"/>

        <!-- ROW 1: Menu Bar (below caption area, normal hit testing) -->
        <local:MenuBar x:Name="MenuBar" Grid.Row="1"/>

        <!-- ROW 2: Navigation Toolbar -->
        <local:NavigationToolbar x:Name="NavToolbar" Grid.Row="2"/>

        <!-- ROW 3: Tab Strip + Two-Panel Layout -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab Strip -->
            <Grid Grid.Row="0" Background="{StaticResource ToolbarBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="TabStripPanel" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="6,0,0,0"/>
                </ScrollViewer>
                <!-- Add Tab Button -->
                <Button Grid.Column="1" x:Name="AddTabButton" Width="24" Height="22"
                        Margin="0,0,8,0" Click="AddTabButton_Click"
                        Background="Transparent" BorderThickness="0" Focusable="False"
                        ToolTip="New Tab (Ctrl+T)">
                    <Viewbox Width="12" Height="12" Stretch="Uniform">
                        <Canvas Width="10" Height="10">
                            <Path Data="M5,0 L5,10 M0,5 L10,5"
                                  Stroke="{StaticResource IconSecondaryBrush}"
                                  StrokeThickness="1.5" StrokeLineJoin="Round"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>

            <!-- Sidebar + File Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <local:SidebarPanel Grid.Column="0" x:Name="SidebarPanel"/>

                <!-- File Grid View -->
                <local:FileGridView Grid.Column="1" x:Name="FileGrid"/>
            </Grid>
        </Grid>

        <!-- ROW 4: Status Bar -->
        <local:StatusLayout x:Name="StatusBar" Grid.Row="4"/>
    </Grid>
</Window>