<UserControl x:Class="DotNetFM.FileGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DotNetFM">

    <UserControl.Resources>
        <Thickness x:Key="ItemMargin">4</Thickness>

        <Style x:Key="ScrollThumbs" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="RectangleCorner"
                                Background="{StaticResource ScrollThumbDefault}"
                                CornerRadius="{StaticResource CornerRadiusScrollThumb}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RectangleCorner" Property="Background" Value="{StaticResource ScrollThumbHover}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="RectangleCorner" Property="Background" Value="{StaticResource ScrollThumbDragging}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="{StaticResource SizeScrollBarWidth}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="Transparent" ClipToBounds="True" Width="{TemplateBinding Width}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbs}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}" ClipToBounds="True">

        <ScrollViewer x:Name="FileScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent"
                      Margin="0,0,5,0"
                      PreviewMouseWheel="FileScrollViewer_PreviewMouseWheel">

            <ItemsControl x:Name="FolderItemsControl" Margin="{StaticResource SpacingContentMargin}"
                          ItemsSource="{Binding Folders, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="local:FolderItem">
                        <Border x:Name="ItemBorder" Cursor="Hand"
                                Margin="{DynamicResource  ItemMargin}" CornerRadius="{StaticResource CornerRadiusLarge}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource HoverHighlightBrush}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SelectedItemBackground}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel Orientation="Vertical"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Margin="{StaticResource SpacingItemPadding}"
                                        Width="{Binding IconSize,
                                                RelativeSource={RelativeSource AncestorType=local:FileGridView},
                                                ConverterParameter=2.0}">

                                <!-- Fixed-height zone keeps row heights uniform in the WrapPanel -->
                                <Border Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=local:FileGridView}}"
                                        HorizontalAlignment="Stretch"
                                        Margin="{StaticResource SpacingIconBottomMargin}">
                                    <Image x:Name="IconImage"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           MaxWidth="{Binding IconSize, RelativeSource={RelativeSource AncestorType=local:FileGridView}}"
                                           MaxHeight="{Binding IconSize, RelativeSource={RelativeSource AncestorType=local:FileGridView}}"
                                           Source="{Binding NativeIcon}"/>
                                </Border>

                                <TextBlock x:Name="NameText"
                                           Text="{Binding Name}"
                                           FontSize="{StaticResource FontFileNameSize}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           LineHeight="12"
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                         Background="{StaticResource InputBackground}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="{StaticResource IconBrush}"
                                         BorderThickness="1"
                                         FontSize="{StaticResource FontFileNameSize}"
                                         Padding="{StaticResource SpacingCompactPadding}"
                                         HorizontalAlignment="Stretch"
                                         VerticalContentAlignment="Center"
                                         KeyDown="RenameBox_KeyDown"
                                         LostFocus="RenameBox_LostFocus">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <TextBlock Text="{Binding ItemCount}"
                                           FontSize="{StaticResource FontFileDetailsSize}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="{StaticResource SpacingItemCountMargin}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>