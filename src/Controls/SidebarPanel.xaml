<UserControl x:Class="dot_net_fm.SidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
             xmlns:local="clr-namespace:dot_net_fm">

    <UserControl.Resources>
        <Style x:Key="SidebarItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverSidebarBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Background="{StaticResource SidebarBrush}" VerticalScrollBarVisibility="Hidden"
                  BorderThickness="0,0,1,0" BorderBrush="{StaticResource SeparatorBrush}">
        <StackPanel Margin="{StaticResource SpacingOuterMargin}">
            <!-- My Computer section -->
            <StackPanel Margin="{StaticResource SpacingChildSectionMargin}">
                <Grid Height="{StaticResource SizeSectionHeaderHeight}" Margin="{StaticResource SpacingHeaderMargin}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x25BE;" FontSize="10" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1" Text="MY COMPUTER" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding MyComputerItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="local:SidebarItem+Item">
                            <Border Height="{StaticResource SizeSidebarItemHeight}" Padding="{StaticResource SpacingSidebarItemPadding}" Cursor="Hand" MouseLeftButtonDown="SidebarItem_MouseLeftButtonDown"
                                    Style="{StaticResource SidebarItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <svg:SvgViewbox UriSource="{Binding IconPath, Converter={StaticResource StringToUriConverter}}" Width="{StaticResource SizeIconSize}" Height="{StaticResource SizeIconSize}" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="{StaticResource SpacingItemTextMargin}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Network section -->
            <StackPanel Margin="{StaticResource SpacingSectionMargin}">
                <Grid Height="{StaticResource SizeSectionHeaderHeight}" Margin="{StaticResource SpacingHeaderMargin}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x25BE;" FontSize="10" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1" Text="NETWORK" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding NetworkItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="local:SidebarItem+Item">
                            <Border Height="{StaticResource SizeSidebarItemHeight}" Padding="{StaticResource SpacingSidebarItemPadding}" Cursor="Hand" MouseLeftButtonDown="SidebarItem_MouseLeftButtonDown"
                                    Style="{StaticResource SidebarItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <svg:SvgViewbox UriSource="{Binding IconPath, Converter={StaticResource StringToUriConverter}}" Width="{StaticResource SizeIconSize}" Height="{StaticResource SizeIconSize}" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="{StaticResource SpacingItemTextMargin}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Bookmarks section -->
            <StackPanel Margin="{StaticResource SpacingSectionMargin}">
                <Grid Height="{StaticResource SizeSectionHeaderHeight}" Margin="{StaticResource SpacingHeaderMargin}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x25BE;" FontSize="10" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1" Text="BOOKMARKS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding BookmarkItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="local:SidebarItem+Item">
                            <Border Height="{StaticResource SizeSidebarItemHeight}" Padding="{StaticResource SpacingSidebarItemPadding}" Cursor="Hand" MouseLeftButtonDown="SidebarItem_MouseLeftButtonDown"
                                    Style="{StaticResource SidebarItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <svg:SvgViewbox UriSource="{Binding IconPath, Converter={StaticResource StringToUriConverter}}" Width="{StaticResource SizeIconSize}" Height="{StaticResource SizeIconSize}" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="{StaticResource SpacingItemTextMargin}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>