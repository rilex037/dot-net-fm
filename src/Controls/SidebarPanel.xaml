<UserControl x:Class="DotNetFM.SidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
             xmlns:local="clr-namespace:DotNetFM">

    <UserControl.Resources>

        <!-- Sidebar item hover style -->
        <Style x:Key="SidebarItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverSidebarBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar item template -->
        <DataTemplate x:Key="SidebarItemTemplate" DataType="local:SidebarItem+Item">
            <Border Height="{StaticResource SizeSidebarItemHeight}"
                    Padding="{StaticResource SpacingSidebarItemPadding}"
                    Cursor="Hand"
                    Style="{StaticResource SidebarItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <svg:SvgViewbox UriSource="{Binding IconPath, Converter={StaticResource StringToUriConverter}}"
                                   Width="{StaticResource SizeIconSize}"
                                   Height="{StaticResource SizeIconSize}"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Name}"
                               FontSize="{StaticResource FontSidebarItemSize}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource SpacingItemTextMargin}"/>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <ScrollViewer Background="{StaticResource SidebarBrush}"
                  VerticalScrollBarVisibility="Hidden"
                  BorderThickness="0,0,1,0"
                  BorderBrush="{StaticResource SeparatorBrush}">
        <StackPanel Margin="{StaticResource SpacingSidebarTopMargin}">
            <ItemsControl ItemsSource="{Binding Sections, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="local:SidebarSectionView">
                        <StackPanel Margin="{StaticResource SpacingChildSectionMargin}">

                            <!-- Section header (bold) — clickable to toggle collapse -->
                            <Grid Height="{StaticResource SizeSectionHeaderHeight}"
                                  Margin="{StaticResource SpacingSidebarSectionHeaderMargin}"
                                  Cursor="Hand"
                                  MouseDown="OnSectionHeaderMouseDown">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Collapse/expand icon: ▾ when expanded, ▸ when collapsed -->
                                <TextBlock Grid.Column="0"
                                           FontFamily="{StaticResource AppFontBold}"
                                           FontSize="{StaticResource FontSectionHeaderSize}"
                                           Foreground="{StaticResource SectionHeaderBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#x25BE;"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                    <Setter Property="Text" Value="&#x25B8;"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontFamily="{StaticResource AppFontBold}"
                                           FontSize="{StaticResource FontSectionHeaderSize}"
                                           FontWeight="{StaticResource FontSectionHeaderWeight}"
                                           Foreground="{StaticResource SectionHeaderBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Sidebar items (normal) — visibility bound to IsCollapsed -->
                            <ItemsControl ItemsSource="{Binding Items}"
                                          ItemTemplate="{StaticResource SidebarItemTemplate}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
