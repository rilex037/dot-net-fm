<UserControl x:Class="DotNetFM.StatusLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf">

    <Grid Background="{StaticResource StatusBarBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar collapse toggle button -->
        <Button x:Name="SidebarToggleButton" Grid.Column="0"
                BorderThickness="0" Margin="{StaticResource SpacingStatusBarIconMargin}"
                Cursor="Hand" Click="SidebarToggleButton_Click" Focusable="False">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter VerticalAlignment="Center"/>
                </ControlTemplate>
            </Button.Template>
            <Border x:Name="ToggleBorder"
                    BorderBrush="Black" BorderThickness="0"
                    CornerRadius="4" Padding="4,2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverSidebarBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <svg:SvgViewbox x:Name="SidebarToggleIcon"
                               Width="14" Height="14"
                               Stretch="Uniform"/>
            </Border>
        </Button>

        <!-- Status text -->
        <TextBlock x:Name="StatusTextBlock" Grid.Column="1" Text="" FontSize="{StaticResource FontStatusSize}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Zoom slider (bottom-right) — steps: 48, 64, 128, 256, 512 -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource SpacingZoomGroupMargin}">
            <Slider x:Name="ZoomSlider" Width="80" Height="20" Background="Transparent" BorderThickness="0"
                    ValueChanged="ZoomSlider_ValueChanged"
                    Style="{StaticResource ZoomSliderStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>
