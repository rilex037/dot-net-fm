<UserControl x:Class="DotNetFM.AlertBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="440" MinHeight="180"
             IsHitTestVisible="True">

    <Border x:Name="CardBorder"
            Background="{StaticResource ToolbarBrush}"
            CornerRadius="{StaticResource CornerRadiusLarge}"
            BorderBrush="{StaticResource SeparatorBrush}"
            BorderThickness="1"
            Padding="24"
            Margin="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Close button -->
            <Button Grid.Row="0" HorizontalAlignment="Right"
                    Background="Transparent" BorderThickness="0"
                    Width="24" Height="24" Cursor="Hand"
                    Click="CloseButton_Click" Focusable="False"
                    Margin="0,-8,-8,0">
                <Viewbox Width="10" Height="10" Stretch="Uniform">
                    <Canvas Width="10" Height="10">
                        <Path Data="M1,1 L9,9 M9,1 L1,9"
                              Stroke="{StaticResource IconSecondaryBrush}"
                              StrokeThickness="1.5" StrokeLineJoin="Round"/>
                    </Canvas>
                </Viewbox>
            </Button>

            <!-- Error icon -->
            <Grid Grid.Row="0" HorizontalAlignment="Left"
                  Width="40" Height="40" Margin="0,0,0,12">
                <Ellipse Fill="{StaticResource AccentBrush}" Opacity="0.15"/>
                <Path Data="M5,2 L5,22 M5,26 L5,27"
                      Stroke="{StaticResource AccentBrush}"
                      StrokeThickness="2.5"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Stretch="Uniform" Width="8" Height="24"
                      Margin="0,-2,0,0"/>
            </Grid>

            <!-- Title -->
            <TextBlock Grid.Row="1"
                       x:Name="TitleText"
                       FontSize="{StaticResource FontFileNameSize}"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"/>

            <!-- Subtitle -->
            <TextBlock Grid.Row="2"
                       x:Name="MessageText"
                       FontSize="{StaticResource FontStatusSize}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <!-- OK button -->
            <Button Grid.Row="3"
                    x:Name="OkButton"
                    Content="OK"
                    Height="30"
                    HorizontalAlignment="Stretch"
                    Background="{StaticResource InputBackground}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource SeparatorBrush}"
                    BorderThickness="1"
                    FontSize="{StaticResource FontStatusSize}"
                    Cursor="Hand"
                    Click="OkButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="{StaticResource CornerRadiusLarge}"
                                            Padding="0,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</UserControl>