<Application x:Class="FmDn.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FmDn"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <local:StringToUriConverter x:Key="StringToUriConverter"/>
        <local:IconSizeStepConverter x:Key="IconSizeStepConverter"/>
        <!-- Dark Theme Colors -->
        <Color x:Key="BackgroundColor">#1E1E1E</Color>
        <Color x:Key="SidebarBackground">#252525</Color>
        <Color x:Key="ToolbarBackground">#2A2A2A</Color>
        <Color x:Key="TextPrimary">#E8E8E8</Color>
        <Color x:Key="TextSecondary">#888888</Color>
        <Color x:Key="SectionHeaderColor">#AAAAAA</Color>
        <Color x:Key="FolderGreen">#8AB200</Color>
        <Color x:Key="FolderTabGreen">#9DC400</Color>
        <Color x:Key="ButtonHover">#3A3A3A</Color>
        <Color x:Key="SeparatorColor">#333333</Color>
        <Color x:Key="StatusBarBackground">#1A1A1A</Color>
        <Color x:Key="SliderTrack">#444444</Color>
        <Color x:Key="SliderThumb">#888888</Color>
        <Color x:Key="IconColor">#CCCCCC</Color>
        <Color x:Key="IconColorSecondary">#AAAAAA</Color>
        <Color x:Key="BreadcrumbBackground">#333333</Color>
        <Color x:Key="AccentColor">#E91E63</Color>
        <!-- Brushes -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarBackground}"/>
        <SolidColorBrush x:Key="ToolbarBrush" Color="{StaticResource ToolbarBackground}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="SectionHeaderBrush" Color="{StaticResource SectionHeaderColor}"/>
        <SolidColorBrush x:Key="FolderGreenBrush" Color="{StaticResource FolderGreen}"/>
        <SolidColorBrush x:Key="FolderTabGreenBrush" Color="{StaticResource FolderTabGreen}"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="{StaticResource ButtonHover}"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}"/>
        <SolidColorBrush x:Key="StatusBarBrush" Color="{StaticResource StatusBarBackground}"/>
        <SolidColorBrush x:Key="SliderTrackBrush" Color="{StaticResource SliderTrack}"/>
        <SolidColorBrush x:Key="SliderThumbBrush" Color="{StaticResource SliderThumb}"/>
        <SolidColorBrush x:Key="IconBrush" Color="{StaticResource IconColor}"/>
        <SolidColorBrush x:Key="IconSecondaryBrush" Color="{StaticResource IconColorSecondary}"/>
        <SolidColorBrush x:Key="BreadcrumbBrush" Color="{StaticResource BreadcrumbBackground}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>

        <!-- Global Styles -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- Zoom Thumb Style -->
        <Style x:Key="ZoomThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Width="12" Height="12"
                                 Fill="{StaticResource SliderThumbBrush}"
                                 Stroke="{StaticResource SliderThumbBrush}"
                                 StrokeThickness="0.5"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Zoom Slider Style — snaps to 6 discrete icon-size steps (0–5) -->
        <Style x:Key="ZoomSliderStyle" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="5"/>
            <Setter Property="Value" Value="2"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="IsDirectionReversed" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="14" SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Track line -->
                            <Border Grid.Row="0" Height="4"
                                    Background="{StaticResource SliderTrackBrush}"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"/>
                            <!-- Track with interactive Thumb -->
                            <Track x:Name="PART_Track" Grid.Row="0"
                                   VerticalAlignment="Center">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="12" Height="12"
                                           Style="{StaticResource ZoomThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>