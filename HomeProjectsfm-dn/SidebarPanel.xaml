<UserControl x:Class="FmDn.SidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
             xmlns:local="clr-namespace:FmDn">

    <UserControl.Resources>
        <!-- Sidebar item style with hover -->
        <SolidColorBrush x:Key="HoverSidebarBrush" Color="#15FFFFFF"/>
        <Style x:Key="SidebarItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverSidebarBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Background="{StaticResource SidebarBrush}" VerticalScrollBarVisibility="Hidden"
                  BorderThickness="0,0,1,0" BorderBrush="{StaticResource SeparatorBrush}">
        <StackPanel Margin="0,4,0,0">
            <!-- My Computer section -->
            <StackPanel Margin="0,0,0,4">
                <Grid Height="24" Margin="8,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x25BE;" FontSize="10" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1" Text="MY COMPUTER" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding MyComputerItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="local:SidebarItem">
                            <Border Height="26" Padding="20,0,0,0" Cursor="Hand" MouseLeftButtonDown="SidebarItem_MouseLeftButtonDown"
                                    Style="{StaticResource SidebarItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <svg:SvgViewbox UriSource="{Binding IconPath, Converter={StaticResource StringToUriConverter}}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Network section -->
            <StackPanel Margin="0,8,0,0">
                <Grid Height="24" Margin="8,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x25BE;" FontSize="10" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1" Text="NETWORK" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding NetworkItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="local:SidebarItem">
                            <Border Height="26" Padding="20,0,0,0" Cursor="Hand" MouseLeftButtonDown="SidebarItem_MouseLeftButtonDown"
                                    Style="{StaticResource SidebarItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <svg:SvgViewbox UriSource="{Binding IconPath, Converter={StaticResource StringToUriConverter}}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Bookmarks section -->
            <StackPanel Margin="0,8,0,0">
                <Grid Height="24" Margin="8,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x25BE;" FontSize="10" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1" Text="BOOKMARKS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SectionHeaderBrush}" VerticalAlignment="Center"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding BookmarkItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="local:SidebarItem">
                            <Border Height="26" Padding="20,0,0,0" Cursor="Hand" MouseLeftButtonDown="SidebarItem_MouseLeftButtonDown"
                                    Style="{StaticResource SidebarItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <svg:SvgViewbox UriSource="{Binding IconPath, Converter={StaticResource StringToUriConverter}}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>